{
  "name": "example-percy-plugin-cypress",
  "version": "0.1.0",
  "private": true,
  "description": "Cypress + Lumina demo app for the Percy Visual Testing plugin's integrate / expand-coverage skills. Starts with NO Percy.",
  "scripts": {
