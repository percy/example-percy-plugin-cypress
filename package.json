    "test": "start-server-and-test serve http://localhost:5599 cy:run"
  },
  "devDependencies": {
    "@percy/cli": "^1.32.3",
    "@percy/cypress": "^3.1.8",
    "cypress": "^15.18.1",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.0.8"
  }
}
